{
  "name": "@belal-elsabbagh-apex/copilot-mcp",
  "version": "1.21.0",
  "type": "module",
  "description": "MCP server exposing EHR Copilot tools: prod->pre-prod order clone, queue-item build, and UiPath Orchestrator execution analysis",
  "author": "Belal Elsabbagh",
  "license": "UNLICENSED",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/belal-elsabbagh-apex/copilot-mcp.git"
  },
  "main": "dist/server.js",
  "bin": {
    "copilot-mcp": "dist/server.js"
  },
  "files": [
    "dist",
    "copilot-mcp.config.example.json",
    "README.md"
  ],
  "engines": {
    "node": ">=18",
    "bun": ">=1.1.0"
  },
  "scripts": {
    "build": "bun build src/server.ts --target node --format esm --minify --outfile dist/server.js && chmod +x dist/server.js",
    "start": "bun run src/server.ts",
    "dev": "bun --watch src/server.ts",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src",
    "format": "biome format --write src",
    "inspect": "bunx @modelcontextprotocol/inspector bun run src/server.ts",
    "prepare": "lefthook install || true; bun run build",
    "prepack": "bun run build",
    "prepublishOnly": "bun run typecheck && bun run build"
  },
  "dependencies": {},
  "devDependencies": {
    "@biomejs/biome": "^2.5.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@types/bun": "^1.3.14",
    "@types/node": "^22.20.0",
    "lefthook": "^2.1.9",
    "typescript": "^5.9.3",
    "zod": "^3.25.76"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted"
  }
}
