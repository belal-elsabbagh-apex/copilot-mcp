{
  "_note": "Copy to config.local.json (gitignored) and point COPILOT_MCP_CONFIG at it. copilot.profiles is optional (per-account creds); top-level copilot.prod/pre_prod are used when no profile is passed. The uipath.noteBucket/queueUrl/addQueueItemPath/serverUrlByEnv fields are only needed for build_queue_item. overrides is optional (per-prodUid clone remaps). Alternatively set COPILOT_MCP_LOCAL_DIR to a dir holding the legacy split files order-copy-credentials.json + uipath-config.json (+ overrides.json).",
  "copilot": {
    "prod": { "be": "https://prod-be-batch.ehrcopilotbe.com", "email": "user@apexmedical.ai", "password": "<redacted>", "fe": "https://copilot.apexmedical.ai" },
    "pre_prod": { "be": "https://pre-prod-be-batch.ehrcopilotbe.com", "email": "user@apexmedical.ai", "password": "<redacted>", "fe": "https://pre-prod-copilot.apexmedicalai.com" },
    "profiles": {
      "ossm": { "prod": { "be": "...", "email": "...", "password": "..." }, "pre_prod": { "be": "...", "email": "...", "password": "..." } },
      "kafri": { "prod": { "be": "...", "email": "...", "password": "..." }, "pre_prod": { "be": "...", "email": "...", "password": "..." } }
    }
  },
  "uipath": {
    "orchestratorUrl": "https://cloud.uipath.com/apexmedicalaiinc/DefaultTenant/orchestrator_",
    "bearer": "<UiPath Personal Access Token with OR.Jobs read scope>",
    "folderPathByEnv": { "prod": "Authorization", "pre_prod": "Authorization Dev Clone" },
    "folderPath": "Authorization",
    "noteBucket": "<s3 note bucket>",
    "queueUrl": "<queue url used in SpecificContent>",
    "addQueueItemPath": "/odata/Queues/UiPathODataSvc.AddQueueItem",
    "serverUrlByEnv": { "prod": "https://prod-be-batch.ehrcopilotbe.com", "pre_prod": "https://pre-prod-be-batch.ehrcopilotbe.com" }
  },
  "overrides": {
    "<prodOrderUid>": { "referredFacilityUid": "<preprod-uid>", "specialityUid": "<preprod-uid>", "placeOfService": "11", "injectCPTs": false }
  },
  "feedback": { "enabled": true, "repositoryUrl": "https://github.com/belal-elsabbagh-apex/copilot-mcp" }
}
